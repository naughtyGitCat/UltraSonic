{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "AgentId": "",
    "MasterEndpoint": "http://localhost:5281",
    "ScanPaths": [
      "D:\\Photograph"
    ],
    "ScanIntervalMinutes": 60,
    "SupportedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".bmp",
      ".webp",
      ".heic",
      ".dng",
      ".cr2",
      ".nef",
      ".arw",
      ".mp4",
      ".mov",
      ".avi",
      ".mkv",
      ".mts"
    ]
  }
}